# ══════════════════════════════════════════════════════
#  ImmoFacile — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
#  Ne JAMAIS committer le fichier .env réel sur Git !
# ══════════════════════════════════════════════════════

# ── Django ─────────────────────────────────────────────
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire

DEBUG=False

# Domaines autorisés (séparés par virgule, sans espace)
# Exemple : monsite.up.railway.app,www.immofacile.sn,immofacile.sn
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données PostgreSQL ──────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=immofacile_db
DB_USER=immofacile_user
DB_PASSWORD=mot_de_passe_fort
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require

# ── Email ───────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application-gmail
DEFAULT_FROM_EMAIL=ImmoFacile <noreply@immofacile.sn>

# ── Redis (optionnel — améliore les performances) ───────
# REDIS_URL=redis://localhost:6379/0

# ── Django settings module ──────────────────────────────
DJANGO_SETTINGS_MODULE=immofacile.settings_production
